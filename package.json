{
  "name": "mini-militia-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser deathmatch remake reusing Mini Militia maps/art (private play only).",
  "scripts": {
    "extract": "node tools/extract.js",
    "build:client": "vite build",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "dev": "concurrently -k -n client,server -c cyan,green \"npm:dev:client\" \"npm:dev:server\"",
    "start": "node server/index.js",
    "test": "node server/sim.test.js"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.35",
    "colyseus": "^0.15.17",
    "express": "^4.19.2",
    "matter-js": "^0.19.0",
    "poly-decomp": "^0.3.0"
  },
  "devDependencies": {
    "colyseus.js": "^0.15.26",
    "concurrently": "^8.2.2",
    "fast-xml-parser": "^4.4.1",
    "phaser": "^3.80.1",
    "sharp": "^0.33.4",
    "vite": "^5.3.4"
  }
}
